# =============================================================================
# Unigent — Environment Variables
# =============================================================================
# Copy this to .env and fill in values.
# For production, set these in your hosting platform (Vercel, etc.)
# =============================================================================

# --- Database ---
DATABASE_URL="postgres://unigent:postgres@localhost:5432/unigent"

# --- Corsair (Google OAuth encryption) ---
CORSAIR_KEK=""

# --- Google OAuth (required for Gmail + Calendar integrations) ---
# Get from: https://console.cloud.google.com/apis/credentials
# Use the Web client ID and secret from the OAuth 2.0 credential
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Clerk Authentication ---
# Get from: https://dashboard.clerk.com → API Keys
# Development: pk_test_... / sk_test_...
# Production:  pk_live_... / sk_live_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
CLERK_PUBLISHABLE_KEY=""

# --- Email (Resend) ---
# Get from: https://resend.com/api-keys
# For production, verify your domain at https://resend.com/domains
RESEND_API_KEY=""
EMAIL_FROM="Unigent <noreply@unigent.in>"

# --- App URL ---
# Development: http://localhost:3000
# Production:  https://unigent.in
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Admin Panel (local dev only, ignored in production) ---
ADMIN_PASSWORD="unigent-admin-2026"
